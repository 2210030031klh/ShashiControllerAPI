###
# Get all budgets (to find budget ID)
GET {{ShashiControllerAPI_HostAddress}}/api/Budget
Authorization: "eyJhbGciOiJIUzUxMiIsInR5cCI6IkpXVCJ9..b4unm_4NjXelQLd5yqdff2AjY5nlKHoS2hwGRH0YhAzyY3ak4oJgfvsGM0sP8P_2PuOqJaZ4kPs1LKSJ_XC7YQ",
Accept: application/json

###
# Update Budget - Replace {id} with actual budget ID from GET response
PUT {{ShashiControllerAPI_HostAddress}}/api/Budget/{id}
Authorization: Bearer your-jwt-token-here
Content-Type: application/json

{
  "categoryId": 1,
  "amount": 5000,
  "month": 3,
  "year": 2024
}

###
# Delete Budget - Replace {id} with actual budget ID from GET response
DELETE {{ShashiControllerAPI_HostAddress}}/api/Budget/{id}
Authorization: Bearer your-jwt-token-here
